{
  "name": "wombat-remote",
  "version": "0.1.0",
  "description": "Self-hosted remote desktop with screen streaming and full input control (à la Chrome Remote Desktop), built on Electron + WebRTC + nut.js.",
  "main": "host/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "server": "node server/index.js",
    "host": "electron .",
    "rebuild": "electron-rebuild -f -w @nut-tree-fork/libnut",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis",
    "postinstall": "electron-rebuild -f -w @nut-tree-fork/libnut || exit 0"
  },
  "build": {
    "appId": "com.wombat.remote",
    "productName": "Wombat Remote",
    "files": [
      "host/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "express": "^4.22.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^25.0.0"
  }
}
